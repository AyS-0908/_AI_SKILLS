{
  "schema": 3,
  "runtime": {
    "requires_pwsh": "7.2",
    "note": "PowerShell performs deterministic inventory, validation, rendering, apply and rollback preparation. The host agent performs semantic organization."
  },
  "extraction": {
    "extract_char_cap": 12000,
    "zip_entry_byte_cap": 5000000,
    "zip_total_byte_cap": 50000000,
    "pdf_max_pages": 20
  },
  "analysis": {
    "batch_limits": {
      "max_files": 25,
      "max_total_chars": 120000
    }
  },
  "organization": {
    "level_2_min_files": 4,
    "archive_destination": "_ARCHIVE",
    "artifacts_dir": "_DATA_CLEANING",
    "max_folder_depth": 2,
    "startup_level1": [
      "ROOT",
      "1-MANAGEMENT",
      "2-SOLUTION",
      "3-CLIENT",
      "to_review"
    ]
  },
  "pdf_extractors": ["pdftotext"],
  "tiers": {
    "note": "Optional host guidance only; tier provenance is not part of the mandatory output contract.",
    "bulk": "clear single-file summaries",
    "standard": "cross-file comparison",
    "complex": "version chains, near-duplicates, contradictions, or low confidence"
  },
  "extensions": {
    "text": [".txt", ".md", ".markdown", ".csv", ".tsv", ".log", ".json", ".xml", ".yaml", ".yml", ".ini", ".cfg", ".conf", ".html", ".htm", ".rtf"],
    "code": [".ps1", ".psm1", ".py", ".js", ".ts", ".tsx", ".jsx", ".java", ".c", ".h", ".cpp", ".cs", ".go", ".rb", ".rs", ".sh", ".sql", ".r", ".php", ".css", ".scss", ".vue"],
    "word": [".docx"],
    "excel": [".xlsx"],
    "ppt": [".pptx"],
    "pdf": [".pdf"],
    "image": [".jpg", ".jpeg", ".png", ".gif", ".bmp", ".tif", ".tiff", ".webp", ".heic", ".ico"],
    "temp": [".tmp", ".temp", ".bak", ".old", ".crdownload", ".part", ".partial", ".swp"],
    "binary_skip": [".exe", ".dll", ".zip", ".7z", ".rar", ".gz", ".mp4", ".mov", ".avi", ".mp3", ".wav", ".iso", ".msi", ".bin", ".doc", ".xls", ".ppt"]
  }
}
