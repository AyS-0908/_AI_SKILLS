{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "folder-cleaning plan.json",
  "type": "object",
  "required": ["schema", "source", "mode", "operations", "decisions", "source_hash_index"],
  "properties": {
    "schema": { "const": 1 },
    "generated": { "type": "string" },
    "source": { "type": "string" },
    "mode": { "type": "string", "enum": ["analyze"] },
    "ai_ran": { "type": "boolean" },
    "source_hash_index": {
      "type": "object",
      "description": "rel_path -> SHA-256. Phase 7 re-hashes the source before apply and aborts if any value here no longer matches.",
      "additionalProperties": { "type": "string" }
    },
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "rel_path", "op"],
        "properties": {
          "id": { "type": "string" },
          "rel_path": { "type": "string" },
          "op": { "type": "string", "enum": ["keep", "archive", "review", "move", "rename"] },
          "to": { "type": ["string", "null"], "description": "destination rel_path for archive/move/rename; under _ARCHIVE/<bucket>/ for archive" },
          "label": { "type": "string" },
          "reason": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "size_bytes": { "type": "integer" }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "rel_path", "question"],
        "properties": {
          "id": { "type": "string" },
          "rel_path": { "type": "string" },
          "question": { "type": "string" },
          "evidence": { "type": "string" }
        }
      }
    }
  }
}
